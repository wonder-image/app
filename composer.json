{
    "name": "wonder-image/app",
    "version": "2.1.0",
    "description": "Wonder Image Framework",
    "homepage": "https://www.wonderimage.it/",
    "keywords": [ "framework",  "Wonder Image", "Wonderimage" ],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Andrea Marinoni",
            "email": "marinoni@wonderimage.it"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "php": "^8.2",
        "fpdf/fpdf": "^1.86",
        "vlucas/phpdotenv": "^5.6",
        "phpmailer/phpmailer": "^6.9",
        "chillerlan/php-qrcode": "^5.0",
        "stripe/stripe-php": "^17.2",
        "firebase/php-jwt": "^6.11",
        "phpoffice/phpspreadsheet": "^5.1",
        "intervention/image": "^3.11",
        "fattureincloud/fattureincloud-php-sdk": "^2.1",
        "getbrevo/brevo-php": "^4.0",
        "klaviyo/api": "^18.0",
        "symfony/console": "^6.4 || ^7.0",
        "symfony/dependency-injection": "^6.4 || ^7.0",
        "symfony/http-foundation": "^6.4 || ^7.0",
        "symfony/routing": "^6.4 || ^7.0"
    },
    "autoload": {
        "psr-4": {
            "Wonder\\": "class/"
        }
    },
    "config": {
        "platform": {
            "php": "8.2.30"
        },
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
